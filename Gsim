<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GT G-Force & Gimbal Simulator</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Noto Sans JP', sans-serif;
            background-color: #0b0f19;
            color: #f3f4f6;
        }
        .hud-font {
            font-family: 'Share Tech Mono', monospace;
        }
        .lcd-font {
            font-family: 'Orbitron', sans-serif;
        }
    </style>
</head>
<body class="min-h-screen overflow-x-hidden flex flex-col pb-8">

    <!-- ヘッダー -->
    <header class="bg-[#111827] border-b border-red-600/40 py-3 px-6 shadow-lg flex justify-between items-center">
        <div class="flex items-center space-x-3">
            <span class="bg-red-600 text-white font-black px-3 py-1 rounded italic text-lg lcd-font tracking-wider">GT</span>
            <div>
                <h1 class="text-xl font-bold tracking-tight text-gray-100 flex items-center">
                    G-FORCE & GIMBAL SIMULATOR
                </h1>
                <p class="text-xs text-red-500 font-bold tracking-widest lcd-font">PHYSICS RESEARCH & MOTION REPRODUCTION</p>
            </div>
        </div>
        <div class="flex items-center space-x-4">
            <div id="status-badge" class="px-3 py-1 rounded-full text-xs font-bold bg-amber-500/20 text-amber-400 border border-amber-500/30 flex items-center gap-1.5 animate-pulse">
                <span class="w-2 h-2 rounded-full bg-amber-400"></span> READY
            </div>
        </div>
    </header>

    <!-- メインコンテンツ -->
    <main class="flex-grow max-w-7xl w-full mx-auto p-4 lg:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- 左カラム：ビジュアル・計測部 (8/12) -->
        <div class="lg:col-span-8 flex flex-col space-y-6">

            <!-- 1. 走行シミュレーションHUD & 簡易コースマップ -->
            <div class="bg-[#111827]/90 rounded-xl p-4 border border-gray-800 shadow-xl flex flex-col md:flex-row gap-4 items-center">
                <!-- マップ描画エリア -->
                <div class="relative w-full md:w-1/3 h-48 bg-[#0a0f1d] rounded-lg border border-gray-800 overflow-hidden flex flex-col justify-between p-2">
                    <div class="absolute top-2 left-2 z-10">
                        <span class="text-xs font-bold text-gray-400 lcd-font tracking-wider">COURSE VIEW</span>
                    </div>
                    <canvas id="course-map-canvas" class="w-full h-full"></canvas>
                </div>

                <!-- 車両ステータスHUD -->
                <div class="w-full md:w-2/3 grid grid-cols-2 sm:grid-cols-3 gap-3">
                    <div class="bg-[#0b101e] p-3 rounded-lg border border-gray-800 flex flex-col justify-between">
                        <span class="text-[10px] text-red-500 font-bold tracking-wider">SPEED</span>
                        <div class="flex items-baseline justify-end">
                            <span id="hud-speed" class="text-3xl font-black text-white lcd-font">0</span>
                            <span class="text-xs text-gray-400 ml-1">km/h</span>
                        </div>
                    </div>
                    <div class="bg-[#0b101e] p-3 rounded-lg border border-gray-800 flex flex-col justify-between">
                        <span class="text-[10px] text-green-400 font-bold tracking-wider">HORIZONTAL G</span>
                        <div class="flex items-baseline justify-end">
                            <span id="hud-total-g" class="text-3xl font-black text-green-400 lcd-font">0.00</span>
                            <span class="text-xs text-gray-400 ml-1">G</span>
                        </div>
                    </div>
                    <div class="bg-[#0b101e] p-3 rounded-lg border border-gray-800 flex flex-col justify-between">
                        <span class="text-[10px] text-blue-400 font-bold tracking-wider">VERTICAL G</span>
                        <div class="flex items-baseline justify-end">
                            <span id="hud-z-g" class="text-3xl font-black text-blue-400 lcd-font">1.00</span>
                            <span class="text-xs text-gray-400 ml-1">G</span>
                        </div>
                    </div>
                    <!-- 3次元合成G & 各方向G -->
                    <div class="bg-[#0b101e] p-2 rounded-lg border border-gray-800 col-span-2 sm:col-span-3 flex justify-around text-xs hud-font text-gray-300">
                        <div>前後Gx: <span id="val-gx" class="font-bold text-white">0.00G</span> (加減速)</div>
                        <div class="border-l border-gray-800 px-3">左右Gy: <span id="val-gy" class="font-bold text-white">0.00G</span> (旋回)</div>
                        <div class="border-l border-gray-800 px-3">上下Gz: <span id="val-gz" class="font-bold text-white">1.00G</span> (起伏)</div>
                    </div>
                </div>
            </div>

            <!-- 2. G-Bowl & 3Dジンバル振り子 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- G-Bowl & 摩擦円インジケーター -->
                <div class="bg-[#111827] rounded-xl p-5 border border-gray-800 shadow-xl flex flex-col items-center relative">
                    <div class="w-full flex justify-between items-center mb-3">
                        <div class="flex items-center space-x-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                            <h3 class="text-sm font-bold tracking-wider">G-BOWL INDICATOR</h3>
                        </div>
                        <span class="text-[10px] bg-gray-800 text-gray-300 px-2 py-0.5 rounded lcd-font">2D FRICTION CIRCLE</span>
                    </div>
                    <!-- G-Bowl キャンバス -->
                    <div class="relative w-64 h-64 bg-[#0a0f1d] rounded-full border-4 border-gray-800 flex items-center justify-center overflow-hidden shadow-inner">
                        <canvas id="gbowl-canvas" width="256" height="256" class="w-full h-full rounded-full"></canvas>
                    </div>
                    <div class="mt-3 text-center text-xs text-gray-400 flex space-x-3">
                        <span><span class="inline-block w-2.5 h-2.5 bg-green-500 rounded-full mr-1"></span>安全 (&lt;0.2G)</span>
                        <span><span class="inline-block w-2.5 h-2.5 bg-yellow-500 rounded-full mr-1"></span>許容 (0.2~0.4G)</span>
                        <span><span class="inline-block w-2.5 h-2.5 bg-red-500 rounded-full mr-1"></span>限界 (&gt;0.4G)</span>
                    </div>
                </div>

                <!-- 3Dジンバル振り子メーター -->
                <div class="bg-[#111827] rounded-xl p-5 border border-gray-800 shadow-xl flex flex-col items-center">
                    <div class="w-full flex justify-between items-center mb-2">
                        <div class="flex items-center space-x-1.5">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-600"></span>
                            <h3 class="text-sm font-bold tracking-wider">GIMBAL PENDULUM (3D)</h3>
                        </div>
                        <span class="text-[10px] bg-red-950 text-red-400 px-2 py-0.5 rounded font-bold lcd-font">PHYSICAL MODEL</span>
                    </div>
                    <!-- 3Dジンバルキャンバス -->
                    <div class="relative w-64 h-64 bg-[#0a0f1d] rounded-lg border border-gray-800 overflow-hidden flex items-center justify-center cursor-move" id="gimbal-container">
                        <canvas id="gimbal-canvas" width="256" height="256" class="w-full h-full"></canvas>
                        <!-- カメラ回転ガイド -->
                        <div class="absolute bottom-2 right-2 text-[10px] text-gray-400/80 bg-gray-900/60 px-2 py-0.5 rounded pointer-events-none">
                            <i class="fa-solid fa-arrows-spin mr-1"></i>ドラッグで視点回転
                        </div>
                    </div>
                    <div class="mt-2 text-center text-[10px] text-gray-400 leading-relaxed">
                        銀色：外輪(前後Pitch軸) / 金色：内輪(左右Roll軸) <br>
                        Gによりジンバルが傾き、吊るされた重りと上部のオレンジの指針が動きます。
                    </div>
                </div>
            </div>

            <!-- 3. バーチャル「週刊誌2冊重ね」実験 -->
            <div class="bg-[#111827] rounded-xl p-5 border border-gray-800 shadow-xl flex flex-col relative overflow-hidden">
                <div class="absolute -right-16 -top-10 w-40 h-40 bg-red-600/5 rounded-full blur-2xl"></div>
                <div class="w-full flex justify-between items-center mb-4">
                    <div class="flex items-center space-x-2">
                        <span class="text-lg">📚</span>
                        <div>
                            <h3 class="text-sm font-bold">バーチャル「週刊誌2冊重ね」物理実験</h3>
                            <p class="text-[10px] text-gray-400">0.3Gで「ツツー」とズレ始め、0.4G超で「ストーン！」と滑り落ちます</p>
                        </div>
                    </div>
                    <button id="btn-stack-books" class="bg-gray-800 hover:bg-gray-700 text-xs px-3 py-1.5 rounded-lg border border-gray-700 transition flex items-center space-x-1">
                        <i class="fa-solid fa-rotate-left text-red-500"></i>
                        <span>本を積み直す</span>
                    </button>
                </div>

                <!-- 本棚・シミュレート部 -->
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <!-- アニメーション表示 -->
                    <div class="md:col-span-8 bg-[#0a0f1d] h-40 rounded-lg border border-gray-800 relative overflow-hidden flex items-center justify-center">
                        <canvas id="books-canvas" class="w-full h-full"></canvas>
                        <div id="book-slip-indicator" class="absolute top-2 left-2 bg-red-600 text-white font-bold text-[10px] px-2 py-0.5 rounded tracking-widest hidden animate-pulse">SLIPPING!</div>
                        <div id="book-fall-indicator" class="absolute inset-0 bg-red-900/80 flex items-center justify-center flex-col space-y-1 text-white font-black text-sm tracking-widest hidden">
                            <span>🚨 週刊誌が完全に落下しました！ 🚨</span>
                            <span class="text-xs font-normal text-gray-300">0.4Gを超える急なGが発生したためです</span>
                        </div>
                    </div>
                    <!-- 本のステータス情報 -->
                    <div class="md:col-span-4 space-y-2">
                        <div class="bg-[#1c1d2e]/30 p-3 rounded border border-gray-800">
                            <span class="text-[10px] text-gray-400 block">現在の上巻のズレ</span>
                            <div class="flex justify-between items-baseline mt-1">
                                <span id="book-slip-dist" class="text-xl font-bold lcd-font text-white">0.0 mm</span>
                                <span id="book-status" class="text-xs text-green-400 font-bold">安定静止(0.2G以下)</span>
                            </div>
                            <div class="w-full bg-gray-800 h-1.5 rounded-full overflow-hidden mt-2">
                                <div id="book-slip-bar" class="bg-green-500 h-full w-0 transition-all duration-100"></div>
                            </div>
                        </div>
                        <div class="text-[10px] text-gray-400 leading-relaxed">
                            💡 乗り物酔いしやすい人が快適に耐えられる境界線は <span class="text-green-400 font-bold">0.2G以下</span> です。この重ねた本を一度も動かさずにコースを周回することが、究極の滑らかな運転テクニックの証となります。
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- 右カラム：設定・制御パネル (4/12) -->
        <div class="lg:col-span-4 flex flex-col space-y-6">

            <!-- A. 自動走行コントロール -->
            <div class="bg-[#111827] rounded-xl p-5 border border-red-600/30 shadow-xl relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-red-600/10 rounded-full blur-xl"></div>
                <h3 class="text-sm font-bold tracking-wider mb-4 border-b border-gray-800 pb-2 flex items-center gap-1.5 text-red-500">
                    <i class="fa-solid fa-gamepad"></i> SIMULATION CONTROL
                </h3>

                <!-- 走行開始・停止ボタン -->
                <button id="btn-run" class="w-full bg-red-600 hover:bg-red-500 text-white font-black py-4 px-6 rounded-xl border border-red-500 shadow-lg text-lg tracking-widest transition transform active:scale-95 flex items-center justify-center space-x-3 mb-4">
                    <i class="fa-solid fa-play"></i>
                    <span>自動走行 スタート</span>
                </button>

                <div class="space-y-4">
                    <!-- コース選択 -->
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">コースを選択 (グランツーリスモ収録)</label>
                        <select id="select-course" class="w-full bg-neutral-900 border border-neutral-700 text-white p-2 rounded focus:ring-1 focus:ring-red-500 focus:outline-none">
                            <option value="grand_valley">Grand Valley Speedway (5.02 km)</option>
                            <option value="test_course">Test Course (10.34 km) - 超高速オーバル</option>
                            <option value":"seattle">Seattle Circuit (3.86 km) - ジャンピング坂道</option>
                            <option value="laguna">Laguna Seca (3.66 km) - 急降下コークスクリュー</option>
                            <option value="complex_string">Complex String (11.23 km) - 連続スラローム</option>
                        </select>
                    </div>

                    <!-- 走行スタイル・車両タイプ選択 -->
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">車両・走行スタイル</label>
                        <div class="grid grid-cols-2 gap-2">
                            <button id="style-eco" class="py-2.5 px-3 rounded-lg text-xs font-bold border border-emerald-500 bg-emerald-500/10 text-emerald-400 flex flex-col items-center justify-center hover:bg-emerald-500/20 transition duration-150">
                                <i class="fa-solid fa-truck text-base mb-1"></i>
                                <span>日常エコ運転 (2トン車)</span>
                                <span class="text-[9px] font-normal text-emerald-500/90 mt-0.5">滑らか最大0.3G想定</span>
                            </button>
                            <button id="style-race" class="py-2.5 px-3 rounded-lg text-xs font-bold border border-gray-700 bg-gray-900 text-gray-400 flex flex-col items-center justify-center hover:bg-gray-800 transition duration-150">
                                <i class="fa-solid fa-fire text-base mb-1"></i>
                                <span>レースアタック (RS)</span>
                                <span class="text-[9px] font-normal text-gray-500 mt-0.5">限界スリップ 1.5G想定</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- B. ダンパー設定 (DAMPING CHARACTERISTICS) -->
            <div class="bg-[#111827] rounded-xl p-5 border border-gray-800 shadow-xl">
                <h3 class="text-sm font-bold tracking-wider mb-4 border-b border-gray-800 pb-2 flex items-center gap-1.5">
                    <i class="fa-solid fa-sliders"></i> DAMPING PHYSICS (制振設定)
                </h3>

                <div class="space-y-4">
                    <!-- ダンパータイプ -->
                    <div>
                        <label class="block text-xs text-gray-400 mb-1.5">ダンパーの物理的機構</label>
                        <div class="grid grid-cols-3 gap-2 text-center text-[10px] font-bold">
                            <label class="cursor-pointer border border-blue-500 bg-blue-500/10 text-blue-400 p-2 rounded flex flex-col items-center justify-center" id="lbl-damping-liquid">
                                <input type="radio" name="damping-type" value="liquid" checked class="hidden">
                                <i class="fa-solid fa-faucet-drip mb-1"></i>
                                <span>液体ダンパー</span>
                            </label>
                            <label class="cursor-pointer border border-gray-800 bg-gray-900 text-gray-400 p-2 rounded flex flex-col items-center justify-center" id="lbl-damping-magnetic">
                                <input type="radio" name="damping-type" value="magnetic" class="hidden">
                                <i class="fa-solid fa-magnet mb-1"></i>
                                <span>磁気ダンパー</span>
                            </label>
                            <label class="cursor-pointer border border-gray-800 bg-gray-900 text-gray-400 p-2 rounded flex flex-col items-center justify-center" id="lbl-damping-friction">
                                <input type="radio" name="damping-type" value="friction" class="hidden">
                                <i class="fa-solid fa-hand-holding-hand mb-1"></i>
                                <span>摩擦ダンパー</span>
                            </label>
                        </div>
                    </div>

                    <!-- 粘性係数のスライダー -->
                    <div>
                        <div class="flex justify-between text-xs text-gray-400 mb-1">
                            <span>ダンパー減衰の強さ</span>
                            <span id="val-damping" class="text-white font-bold">3.0</span>
                        </div>
                        <input type="range" id="slider-damping" min="0.5" max="8.0" step="0.1" value="3.0" class="w-full accent-red-600 bg-gray-900 rounded-lg appearance-none h-2 cursor-pointer">
                    </div>

                    <div id="damping-explain-box" class="bg-blue-950/20 border border-blue-500/30 rounded p-3 text-[10px] text-blue-300 leading-relaxed">
                        <span class="font-bold text-blue-400 block mb-1">💧 液体ダンパー (Liquid Damper)</span>
                        液体の粘り気を利用した標準的な揺れ防止機能。滑らかですが、温度変化による特性の変化や液漏れの可能性があります。
                    </div>
                </div>
            </div>

            <!-- C. 計器調整 & 音声警告 -->
            <div class="bg-[#111827] rounded-xl p-5 border border-gray-800 shadow-xl">
                <h3 class="text-sm font-bold tracking-wider mb-4 border-b border-gray-800 pb-2 flex items-center gap-1.5">
                    <i class="fa-solid fa-wrench"></i> CALIBRATION & AUDIO
                </h3>

                <div class="space-y-4">
                    <!-- 水平補正ボタン -->
                    <div>
                        <label class="block text-xs text-gray-400 mb-1">スマホ設置時のゼロ点補正</label>
                        <button id="btn-calibrate" class="w-full bg-gray-800 hover:bg-gray-700 text-xs py-2 px-4 rounded border border-gray-700 transition flex items-center justify-center space-x-2">
                            <i class="fa-solid fa-compress text-green-500"></i>
                            <span class="font-bold">現在の位置を 0G（基準）に設定</span>
                        </button>
                        <span class="text-[9px] text-gray-400 block mt-1 leading-normal">
                            スマホホルダーなどで傾けて固定した場合でも、現在の姿勢を「基準」にしてGセンサーをリセットできます。
                        </span>
                    </div>

                    <!-- 音声警告 -->
                    <div class="flex items-center justify-between p-3 bg-gray-900/40 rounded border border-gray-800">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-gray-200">超過アラート音 (🔊 ON)</span>
                            <span class="text-[9px] text-gray-400">0.3G（およそ本のズレ始め）で音を鳴らす</span>
                        </div>
                        <button id="btn-toggle-sound" class="text-xl text-green-400 p-2 rounded hover:bg-gray-800 transition">
                            <i class="fa-solid fa-volume-high"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>

    </main>

    <!-- フッター説明 -->
    <footer class="text-center text-xs text-gray-500 mt-6 max-w-7xl mx-auto w-full px-6 flex flex-col md:flex-row justify-between items-center border-t border-gray-800 pt-4 gap-2">
        <p>© 2026 G-FORCE & GIMBAL SYSTEM DYNAMICS LAB. All rights reserved.</p>
        <p class="lcd-font">PHYSICAL COMPONENT SIMULATION MODEL: VER 2.14</p>
    </footer>

    <!-- Web Audio API の自動再生ポリシー対応用のモーダル -->
    <div id="welcome-modal" class="fixed inset-0 bg-[#070913]/90 flex items-center justify-center z-50 p-4">
        <div class="bg-[#111827] max-w-lg w-full rounded-2xl border border-red-600/30 p-6 shadow-2xl relative">
            <span class="bg-red-600 text-white font-black px-3 py-1 rounded italic text-sm lcd-font tracking-wider absolute -top-3 left-6">GT ACCELERATION SYSTEM</span>
            <h2 class="text-xl font-black text-gray-100 mb-2 mt-2 flex items-center gap-2">
                <i class="fa-solid fa-fire text-red-500"></i> G-Force 物理再現シミュレーターへようこそ
            </h2>
            <div class="text-xs text-gray-300 space-y-3 leading-relaxed mb-6">
                <p>
                    このアプリは、PlayStation専用ソフト<b>『グランツーリスモ3』</b>などで培われた高度な車両運動力学に準拠した、3軸重力加速度および<b>ジンバル式振り子Gメーター</b>の動作を忠実にシミュレートするプログラムです。
                </p>
                <div class="bg-gray-900/60 p-3 rounded-lg border border-gray-800">
                    <span class="font-bold text-red-400 block mb-1">🎮 主な機能と見どころ</span>
                    <ul class="list-disc pl-4 space-y-1">
                        <li><b>コース・車両選択</b>：名門スピードウェイや、シアトルのジャンピング坂、ラグナセカの急勾配での3次元G変化。</li>
                        <li><b>振り子の3D運動物理モデル</b>：減衰ダンパー（液体・電磁・摩擦）によるリアルな挙動の差。</li>
                        <li><b>週刊誌2冊重ね実験</b>：荷重が安定域（0.2G）を超えた瞬間にズレ動く本の実挙動。</li>
                    </ul>
                </div>
                <p class="text-gray-400 text-[10px]">
                    ※しきい値超過音（音声アラート）を使用するため、ブラウザのセキュリティ制限解除を目的として「同意してシミュレーターを開始」ボタンを押してください。
                </p>
            </div>
            <button id="btn-start-simulation" class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-3 px-6 rounded-xl border border-red-500 transition tracking-widest text-center shadow-lg active:scale-95">
                同意してシミュレーターを開始する
            </button>
        </div>
    </div>

    <!-- Script部 -->
    <script>
        // ----------------------------------------------------
        // 1. 各種定数と物理パラメータ設定
        // ----------------------------------------------------
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'gt-gforce-pendulum';

        // コース定義 (時間 t [秒] に対する速度[km/h]、前後G, 左右G, 上下Gのプロファイル関数)
        const Courses = {
            grand_valley: {
                name: "Grand Valley Speedway",
                length: "5,022m",
                duration: 40, // 1周シミュレーションにかける秒数
                getG: function(t, isRace) {
                    // S字コーナー、トンネル、ヘアピン
                    const maxScale = isRace ? 1.4 : 0.28;
                    const speedMax = isRace ? 220 : 60;
                    const speedMin = isRace ? 65 : 30;
                    
                    const progress = t % 40;
                    let speed = speedMax;
                    let ax = 0.0;
                    let ay = 0.0;
                    let az = 1.0; // 通常の1G
                    let sector = "ストレート";

                    if (progress < 8) {
                        // 1. ストレートでの加速
                        ax = 0.3 * Math.sin((progress / 8) * Math.PI / 2);
                        ay = 0.02 * Math.sin(progress * 2);
                        speed = speedMin + (speedMax - speedMin) * (progress / 8);
                        sector = "第1ストレート";
                    } else if (progress < 14) {
                        // 2. Turn 1 (高速左コーナーへの急ブレーキ)
                        const decelProgress = (progress - 8) / 6;
                        ax = -0.8 * Math.sin(decelProgress * Math.PI); // 急減速
                        ay = -0.95 * Math.sin(decelProgress * Math.PI); // 左旋回による右G
                        speed = speedMax - (speedMax - speedMin) * Math.sin(decelProgress * Math.PI / 2);
                        sector = "第1コーナー (高速左)";
                    } else if (progress < 18) {
                        // 3. 第1トンネル内 (緩やかな右)
                        const tunnelProgress = (progress - 14) / 4;
                        ax = 0.1 * Math.sin(tunnelProgress * Math.PI);
                        ay = 0.4 * Math.sin(tunnelProgress * Math.PI); // 左G
                        speed = speedMin + (speedMax - speedMin) * 0.4 * tunnelProgress;
                        sector = "第1トンネル (緩い右)";
                    } else if (progress < 26) {
                        // 4. 連続S字切り返し (左右G激しい蛇行)
                        const sCurveProgress = (progress - 18) / 8;
                        ax = -0.2 * Math.sin(sCurveProgress * Math.PI * 4);
                        ay = 1.1 * Math.sin(sCurveProgress * Math.PI * 3); // 激しく左右へ
                        speed = speedMin + (speedMax - speedMin) * 0.3 * (1 - sCurveProgress);
                        sector = "S字連続切り返し";
                    } else if (progress < 32) {
                        // 5. ヘアピンターン (最強減速と最大横G)
                        const hairpinProgress = (progress - 26) / 6;
                        ax = -1.2 * Math.exp(-hairpinProgress * 2); // フルブレーキング
                        ay = -1.3 * Math.sin(hairpinProgress * Math.PI); // 強烈な右への旋回G
                        speed = speedMin - 15 + (speedMax - speedMin) * 0.1;
                        sector = "ヘアピンコーナー (タイト左)";
                    } else {
                        // 6. 脱出からホームストレート
                        const lastProgress = (progress - 32) / 8;
                        ax = 0.4 * (1 - lastProgress);
                        ay = 0.2 * Math.sin(lastProgress * Math.PI);
                        speed = speedMin + (speedMax - speedMin) * lastProgress;
                        sector = "ホームストレート加速";
                    }

                    return {
                        ax: ax * maxScale,
                        ay: ay * maxScale,
                        az: az + (isRace ? (Math.random() - 0.5) * 0.15 : (Math.random() - 0.5) * 0.03), // リアルな細密な振動
                        speed: speed,
                        sector: sector
                    };
                }
            },
            test_course: {
                name: "Test Course",
                length: "10,342m",
                duration: 40,
                getG: function(t, isRace) {
                    // 超高速オーバル 巨大バンク
                    const progress = t % 40;
                    const speedMax = isRace ? 360 : 80;
                    const speedMin = isRace ? 80 : 50;
                    let speed = speedMax;
                    let ax = 0.0;
                    let ay = 0.0;
                    let az = 1.0;
                    let sector = "超長大ストレート";

                    if (progress < 15) {
                        // 1. ストレート：極限加速
                        const accProgress = progress / 15;
                        ax = 0.45 * Math.pow(1 - accProgress, 2); // 速度上昇につれて加速が鈍化
                        ay = 0.0;
                        speed = speedMin + (speedMax - speedMin) * accProgress;
                        sector = "最高速アタック直線";
                    } else if (progress < 30) {
                        // 2. 超巨大30度バンク進入
                        const bankProgress = (progress - 15) / 15;
                        speed = speedMax - 20 * Math.sin(bankProgress * Math.PI);
                        
                        if (isRace) {
                            // 時速350km超：強い遠心力により、ロール傾斜（カント30度）と合算され、縦圧縮Gが劇的に発生。横Gは遠心力と傾斜が釣り合うためやや減少。
                            ay = 0.3 * Math.sin(bankProgress * Math.PI); // カントが遠心力を打消すため、横Gはマイルド
                            az = 1.0 + 0.65 * Math.sin(bankProgress * Math.PI); // 強烈なボトム圧縮縦G（体輪重圧）
                        } else {
                            // 日常走行（時速80km以下）：バンクが急すぎて、車が内側に滑り落ちるようなマイナス横Gが発生！
                            ay = -0.15 * Math.sin(bankProgress * Math.PI); // イン側に引かれる
                            az = 1.0 + 0.05 * Math.sin(bankProgress * Math.PI);
                        }
                        sector = "超高速30度バンク突入";
                    } else {
                        // 3. バンク脱出、ストレート復帰
                        const exitProgress = (progress - 30) / 10;
                        ax = 0.1;
                        ay = 0.0;
                        speed = speedMax - 20 * (1 - exitProgress);
                        sector = "ホームストレート";
                    }

                    return {
                        ax: ax * (isRace ? 1.0 : 0.2),
                        ay: ay * (isRace ? 1.0 : 0.6),
                        az: az
                    };
                }
            },
            seattle: {
                name: "Seattle Circuit",
                length: "3,863m",
                duration: 40,
                getG: function(t, isRace) {
                    // 市街地急坂・ジャンピング
                    const progress = t % 40;
                    const speedMax = isRace ? 200 : 50;
                    const speedMin = isRace ? 50 : 30;
                    let speed = speedMax;
                    let ax = 0.0;
                    let ay = 0.0;
                    let az = 1.0;
                    let sector = "市街地フラット";

                    if (progress < 10) {
                        // 1. 直角コーナー手前のブレーキと直角曲がり
                        const cornerP = progress / 10;
                        ax = -0.7 * Math.sin(cornerP * Math.PI);
                        ay = 0.8 * Math.sin(cornerP * Math.PI);
                        speed = speedMax - (speedMax - speedMin) * Math.sin(cornerP * Math.PI / 2);
                        sector = "直角市街地ターン";
                    } else if (progress < 18) {
                        // 2. 急激な上り坂
                        const slopeP = (progress - 10) / 8;
                        ax = 0.3 * (1 - slopeP); // 坂を上る負荷
                        ay = 0.0;
                        az = 1.15; // 坂の進入で圧縮
                        speed = speedMin + (speedMax - speedMin) * slopeP;
                        sector = "激しい上り急坂";
                    } else if (progress < 22) {
                        // 3. ★ジャンピング丘（ジャンプ！無重力 0G）
                        const jumpP = (progress - 18) / 4;
                        if (isRace) {
                            if (jumpP < 0.4) {
                                // 飛び出した瞬間 0G
                                az = 0.05; // ほぼ無重力
                                ax = -0.05; // 空力ブレーキ
                                speed = speedMax;
                            } else if (jumpP < 0.6) {
                                // 着地瞬間！！2.5Gを超えるボトムアウト衝撃
                                az = 2.6; // 強烈衝撃
                                ax = -0.3;
                                speed = speedMax - 30;
                            } else {
                                // リバウンド後復帰
                                az = 1.0;
                                speed = speedMax - 20;
                            }
                        } else {
                            // 日常走行：サスペンションがマイルドに吸収し、ジャンプしない
                            az = 1.0 - 0.25 * Math.sin(jumpP * Math.PI);
                            speed = speedMin + 10;
                        }
                        sector = isRace ? "空中ジャンプ＆ボトムアウト！" : "起伏なだらか吸収";
                    } else {
                        // 4. 急制動シケイン
                        const lastP = (progress - 22) / 18;
                        ax = -0.9 * Math.sin(lastP * Math.PI);
                        ay = -0.6 * Math.sin(lastP * Math.PI * 2);
                        speed = speedMin + (speedMax - speedMin) * lastP;
                        sector = "急制動シケイン";
                    }

                    return {
                        ax: ax * (isRace ? 1.0 : 0.25),
                        ay: ay * (isRace ? 1.0 : 0.25),
                        az: az
                    };
                }
            },
