                            az = isRace ? 1.85 : 1.15; // 強いボトム
                            ay = isRace ? 1.2 : 0.3; // 右切り返し
                            ax = isRace ? -0.5 : -0.15;
                            speed = speedMax - 40;
                        } else {
                            // 脱出
                            az = 1.0;
                            ay = 0.0;
                            speed = speedMin + 15;
                        }
                        sector = "コークスクリュー急降下(崖下)";
                    } else {
                        // 高速最終コーナーへの加速
                        const exitP = (progress - 25) / 15;
                        ax = 0.3;
                        ay = -0.7 * Math.sin(exitP * Math.PI);
                        speed = speedMin + (speedMax - speedMin) * exitP;
                        sector = "最終コーナー";
                    }

                    return {
                        ax: ax * (isRace ? 1.0 : 0.25),
                        ay: ay * (isRace ? 1.0 : 0.25),
                        az: az
                    };
