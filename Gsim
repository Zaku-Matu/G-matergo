        // ----------------------------------------------------
        // 4. Web Audio API アラート音システム
        // ----------------------------------------------------
        let audioCtx = null;
        let alertOscillator = null;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        // 短いビープ音
        function playBeep(frequency, duration, volume = 0.1) {
            if (!state.soundEnabled || !audioCtx) return;
            try {
                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                
                osc.type = "sine";
                osc.frequency.value = frequency;
                
                gainNode.gain.setValueAtTime(volume, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
                
                osc.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (e) {
                console.log("Audio playback error:", e);
            }
        }

        // 本の崩落音（連続したガラガラ音）
        function playBookFallSound() {
            if (!state.soundEnabled || !audioCtx) return;
            let time = audioCtx.currentTime;
            for (let i = 0; i < 5; i++) {
                const freq = 120 - i * 15;
                const dur = 0.15;
                setTimeout(() => {
                    playBeep(freq, dur, 0.25);
                }, i * 100);
            }
        }

        // ----------------------------------------------------
        // 5. ジンバル３Dドラッグ制御
        // ----------------------------------------------------
        const gimbalContainer = document.getElementById("gimbal-container");
        gimbalContainer.addEventListener("mousedown", (e) => {
            isDragging = true;
            previousMousePosition = { x: e.clientX, y: e.clientY };
        });
        gimbalContainer.addEventListener("mousemove", (e) => {
            if (!isDragging) return;
            const deltaX = e.clientX - previousMousePosition.x;
            const deltaY = e.clientY - previousMousePosition.y;
            cameraAngleZ -= deltaX * 0.01;
            cameraAngleX += deltaY * 0.01;
            // 制限
            cameraAngleX = Math.max(0.1, Math.min(Math.PI / 2 - 0.1, cameraAngleX));
            previousMousePosition = { x: e.clientX, y: e.clientY };
        });
        window.addEventListener("mouseup", () => {
            isDragging = false;
        });

        // モバイルタッチ操作対応
        gimbalContainer.addEventListener("touchstart", (e) => {
            if (e.touches.length === 1) {
                isDragging = true;
                previousMousePosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
            }
        });
        gimbalContainer.addEventListener("touchmove", (e) => {
            if (!isDragging || e.touches.length !== 1) return;
            const deltaX = e.touches[0].clientX - previousMousePosition.x;
            const deltaY = e.touches[0].clientY - previousMousePosition.y;
            cameraAngleZ -= deltaX * 0.01;
            cameraAngleX += deltaY * 0.01;
            cameraAngleX = Math.max(0.1, Math.min(Math.PI / 2 - 0.1, cameraAngleX));
            previousMousePosition = { x: e.touches[0].clientX, y: e.touches[0].clientY };
        });
        gimbalContainer.addEventListener("touchend", () => {
            isDragging = false;
        });

        // ----------------------------------------------------
        // 6. コースマップ描画機能
        // ----------------------------------------------------
        function drawCourseMap() {
            const w = courseCanvas.width = courseCanvas.clientWidth;
            const h = courseCanvas.height = courseCanvas.clientHeight;
            courseCtx.clearRect(0, 0, w, h);
            
            // コースに沿った軌跡の描画 (ダミー描画だがコースごとにユニークな形状)
            courseCtx.strokeStyle = "rgba(75, 85, 99, 0.4)";
            courseCtx.lineWidth = 4;
            courseCtx.lineJoin = "round";
            courseCtx.lineCap = "round";

            const cx = w / 2;
            const cy = h / 2;
            const rX = w * 0.38;
            const rY = h * 0.32;

            courseCtx.beginPath();
            
            const points = [];
            const segments = 100;
            
            for (let i = 0; i <= segments; i++) {
                const angle = (i / segments) * Math.PI * 2;
                let x = cx + rX * Math.cos(angle);
                let y = cy + rY * Math.sin(angle);
                
                // コース特有の凹凸変形
                if (state.courseKey === "grand_valley") {
                    x += 12 * Math.sin(angle * 4);
                    y += 18 * Math.cos(angle * 3);
                } else if (state.courseKey === "test_course") {
                    // 平たい楕円
                    x = cx + rX * 1.1 * Math.cos(angle);
                    y = cy + rY * 0.7 * Math.sin(angle);
                } else if (state.courseKey === "seattle") {
                    // カクカクした市街地
                    x = cx + rX * (Math.cos(angle) + 0.15 * Math.sin(angle * 3));
                    y = cy + rY * (Math.sin(angle) + 0.15 * Math.cos(angle * 3));
                } else if (state.courseKey === "laguna") {
                    // コークスクリューを表現する複雑なループ
                    x += 15 * Math.sin(angle * 2);
                    y += 25 * Math.sin(angle * 2.5);
                } else if (state.courseKey === "complex_string") {
                    // うねうねスラローム
                    x += 20 * Math.sin(angle * 8);
                    y += 10 * Math.cos(angle * 4);
                }
                points.push({ x, y });
                if (i === 0) courseCtx.moveTo(x, y);
                else courseCtx.lineTo(x, y);
            }
            courseCtx.closePath();
            courseCtx.stroke();

            // トンネルや特異点などのシンボル描画
            if (state.courseKey === "grand_valley") {
                courseCtx.fillStyle = "#3b82f6";
                courseCtx.fillText("TUNNEL 1", cx - 30, cy - rY + 5);
                courseCtx.fillText("TUNNEL 2", cx - 40, cy + rY - 15);
            } else if (state.courseKey === "test_course") {
                courseCtx.fillStyle = "#eab308";
                courseCtx.fillText("巨大30°バンク", cx - 40, cy - rY + 10);
            } else if (state.courseKey === "seattle") {
                courseCtx.fillStyle = "#ef4444";
                courseCtx.fillText("ジャンピング丘", cx - 40, cy - 5);
            } else if (state.courseKey === "laguna") {
                courseCtx.fillStyle = "#a855f7";
                courseCtx.fillText("コークスクリュー (急降下)", cx - 60, cy - 10);
            }

            // 現在地（ドット）のプロット
            if (state.isRunning) {
                const totalDuration = Courses[state.courseKey].duration;
                const tPercent = (state.currentTime % totalDuration) / totalDuration;
                const pointIdx = Math.floor(tPercent * segments);
                const currentPos = points[pointIdx] || points[0];

                // 光るドット
                courseCtx.shadowBlur = 10;
                courseCtx.shadowColor = "#ef4444";
                courseCtx.fillStyle = "#ef4444";
                courseCtx.beginPath();
                courseCtx.arc(currentPos.x, currentPos.y, 6, 0, Math.PI * 2);
                courseCtx.fill();
                courseCtx.shadowBlur = 0; // リセット
            } else {
                // スタート地点
                courseCtx.fillStyle = "#10b981";
                courseCtx.beginPath();
                courseCtx.arc(points[0].x, points[0].y, 6, 0, Math.PI * 2);
                courseCtx.fill();
            }

            // 右上のセクター情報
            courseCtx.fillStyle = "rgba(156, 163, 175, 0.9)";
            courseCtx.font = "bold 9px 'Share Tech Mono'";
            courseCtx.fillText(state.car.sector, 8, h - 8);
        }

        // ----------------------------------------------------
        // 7. G-Bowl グラフィックス & 履歴軌跡
        // ----------------------------------------------------
        let gHistory = []; // Gの履歴を保持する配列 ({x, y})

        function drawGBowl() {
            const w = gbowlCanvas.width;
            const h = gbowlCanvas.height;
            gbowlCtx.clearRect(0, 0, w, h);

            const cx = w / 2;
            const cy = h / 2;
            const maxRadius = w * 0.44; // 端（1.5G相当）

            // 1Gあたりのピクセルスケール（日常なら0.3Gで縁まで。レースなら1.5Gで縁まで調整）
            const gScaleLimit = state.vehicleStyle === "race" ? 1.5 : 0.45;
            const pxPerG = maxRadius / gScaleLimit;

            // 同心円の描画 (0.2G, 0.3G, 0.4G, または 0.5G, 1.0G, 1.5G)
            const circles = state.vehicleStyle === "race" ? [0.5, 1.0, 1.5] : [0.2, 0.3, 0.4];
            const colors = ["rgba(16, 185, 129, 0.15)", "rgba(245, 158, 11, 0.15)", "rgba(239, 68, 68, 0.15)"];
            const borderColors = ["#10b981", "#f59e0b", "#ef4444"];

            circles.forEach((gVal, idx) => {
                const r = gVal * pxPerG;
                gbowlCtx.fillStyle = colors[idx];
                gbowlCtx.strokeStyle = borderColors[idx] + "aa";
                gbowlCtx.lineWidth = 1.5;
                
                gbowlCtx.beginPath();
                gbowlCtx.arc(cx, cy, r, 0, Math.PI * 2);
                gbowlCtx.fill();
                gbowlCtx.stroke();

                // ラベル
                gbowlCtx.fillStyle = borderColors[idx];
                gbowlCtx.font = "9px 'Share Tech Mono'";
                gbowlCtx.fillText(`${gVal}G`, cx + r - 25, cy - 4);
            });

            // 十字線の描画
            gbowlCtx.strokeStyle = "rgba(75, 85, 99, 0.3)";
            gbowlCtx.lineWidth = 1;
            gbowlCtx.beginPath();
            gbowlCtx.moveTo(cx - maxRadius, cy);
            gbowlCtx.lineTo(cx + maxRadius, cy);
            gbowlCtx.moveTo(cx, cy - maxRadius);
            gbowlCtx.lineTo(cx, cy + maxRadius);
            gbowlCtx.stroke();

            // 軌跡（スリップライン）履歴の描画
            if (gHistory.length > 1) {
                gbowlCtx.beginPath();
                gbowlCtx.lineWidth = 2.5;
                for (let i = 0; i < gHistory.length; i++) {
                    // 前後加速は上(12時)、ブレーキは下(6時)、右カーブによる横G(遠心力)は外側。
                    // 座標系変換：前後G(Ax)正は加速→上。左右G(Ay)正は右G。
                    const hX = cx + gHistory[i].y * pxPerG;
                    const hY = cy - gHistory[i].x * pxPerG;
                    if (i === 0) gbowlCtx.moveTo(hX, hY);
                    else gbowlCtx.lineTo(hX, hY);
                }
                // グラデーションの軌跡
                const grad = gbowlCtx.createRadialGradient(cx, cy, 10, cx, cy, maxRadius);
                grad.addColorStop(0, "rgba(239, 68, 68, 0.7)");
                grad.addColorStop(1, "rgba(239, 68, 68, 0.05)");
                gbowlCtx.strokeStyle = grad;
                gbowlCtx.stroke();
            }

            // 現在のボール位置（遅延のない生加速度を表示）
            const bX = cx + state.car.ay * pxPerG;
            const bY = cy - state.car.ax * pxPerG;

            // ボールの影
            gbowlCtx.shadowBlur = 12;
            gbowlCtx.shadowColor = "#ef4444";
            
            // ボール本体
            gbowlCtx.fillStyle = "#ffffff";
            gbowlCtx.strokeStyle = "#ef4444";
            gbowlCtx.lineWidth = 3;
            gbowlCtx.beginPath();
            gbowlCtx.arc(bX, bY, 8, 0, Math.PI * 2);
            gbowlCtx.fill();
            gbowlCtx.stroke();

            gbowlCtx.shadowBlur = 0; // リセット
        }

        // ----------------------------------------------------
        // 8. 3Dジンバル振り子描画機能 (3D射影数学)
        // ----------------------------------------------------
        function drawGimbal3D() {
            const w = gimbalCanvas.width;
            const h = gimbalCanvas.height;
            gimbalCtx.clearRect(0, 0, w, h);

            const cx = w / 2;
            const cy = h / 2 + 10;
            const scale = 70; // 3Dスケール係数

            // 投影関数（3D回転変換）
            function project(x, y, z) {
                // Z軸回転（カメラ水平回転）
                const cosZ = Math.cos(cameraAngleZ);
                const sinZ = Math.sin(cameraAngleZ);
                const x1 = x * cosZ - y * sinZ;
                const y1 = x * sinZ + y * cosZ;

                // X軸回転（俯角）
                const cosX = Math.cos(cameraAngleX);
                const sinX = Math.sin(cameraAngleX);
                const y2 = y1 * cosX - z * sinX;
                const z2 = y1 * sinX + z * cosX;

                // 2D座標に変換
                return {
                    x: cx + x1 * scale,
                    y: cy - y2 * scale,
                    depth: z2
                };
            }

            // A. 台座・フレーム（ベース）
            gimbalCtx.strokeStyle = "rgba(75, 85, 99, 0.4)";
            gimbalCtx.lineWidth = 2;
            const baseCircle = [];
            for (let a = 0; angle = (a / 32) * Math.PI * 2, a <= 32; a++) {
                baseCircle.push(project(Math.cos(angle) * 1.3, Math.sin(angle) * 1.3, -1.1));
            }
            gimbalCtx.beginPath();
            baseCircle.forEach((p, idx) => {
                if (idx === 0) gimbalCtx.moveTo(p.x, p.y);
                else gimbalCtx.lineTo(p.x, p.y);
            });
            gimbalCtx.stroke();

            // 支柱（4本柱）
            const pillars = [
                {x: 1.2, y: 0}, {x: -1.2, y: 0}, {x: 0, y: 1.2}, {x: 0, y: -1.2}
            ];
            gimbalCtx.strokeStyle = "rgba(75, 85, 99, 0.3)";
            pillars.forEach(pil => {
                const bottom = project(pil.x, pil.y, -1.1);
                const top = project(pil.x, pil.y, 0);
                gimbalCtx.beginPath();
                gimbalCtx.moveTo(bottom.x, bottom.y);
                gimbalCtx.lineTo(top.x, top.y);
                gimbalCtx.stroke();
            });

            // B. 外輪 (銀：Pitch軸 前後に回転)
            // 外輪は、左右（Y軸）のピボットで本体に接続され、前後（X軸方向）に傾く
            const thetaX = state.pendulum.thetaX;
            gimbalCtx.strokeStyle = "#94a3b8"; // シルバー色
            gimbalCtx.lineWidth = 5;
            gimbalCtx.beginPath();
            for (let a = 0; angle = (a / 32) * Math.PI * 2, a <= 32; a++) {
                // X軸回転成分を含めた円
                const xLocal = Math.cos(angle);
                const yLocal = Math.sin(angle) * Math.cos(thetaX);
                const zLocal = Math.sin(angle) * Math.sin(thetaX);
                const p = project(xLocal * 1.15, yLocal * 1.15, zLocal * 1.15);
                if (a === 0) gimbalCtx.moveTo(p.x, p.y);
                else gimbalCtx.lineTo(p.x, p.y);
            }
            gimbalCtx.stroke();

            // C. 内輪 (金：Roll軸 左右に回転)
            // 内輪は外輪に直交し、前後（X軸）のピボットで外輪に支持され、左右に傾く
            const thetaY = state.pendulum.thetaY;
            gimbalCtx.strokeStyle = "#fbbf24"; // ゴールド色
            gimbalCtx.lineWidth = 3.5;
            gimbalCtx.beginPath();
            for (let a = 0; angle = (a / 32) * Math.PI * 2, a <= 32; a++) {
                // 外輪の傾き(thetaX)と、内輪独自の傾き(thetaY)の複合回転
                const xRaw = Math.sin(angle) * Math.sin(thetaY);
                const yRaw = Math.cos(angle);
                const zRaw = Math.sin(angle) * Math.cos(thetaY);

                // 外輪の回転を適用
                const xRot = xRaw;
                const yRot = yRaw * Math.cos(thetaX) - zRaw * Math.sin(thetaX);
                const zRot = yRaw * Math.sin(thetaX) + zRaw * Math.cos(thetaX);

                const p = project(xRot * 0.95, yRot * 0.95, zRot * 0.95);
                if (a === 0) gimbalCtx.moveTo(p.x, p.y);
                else gimbalCtx.lineTo(p.x, p.y);
            }
            gimbalCtx.stroke();

            // D. 吊り下げ振り子シャフト ＆ 重り ＆ 指針
            // 内輪の傾きが直接振り子（重り）に伝達される
            // 振り子の先端位置ベクトル
            const length = 0.9;
            const fX = Math.sin(thetaY);
            const fY = Math.sin(thetaX) * Math.cos(thetaY);
            const fZ = -Math.cos(thetaX) * Math.cos(thetaY);

            const pivot = project(0, 0, 0);
            const weightPos = project(fX * length, fY * length, fZ * length);
            const needlePos = project(-fX * 0.5, -fY * 0.5, -fZ * 0.5); // 上に伸びる針

            // 振り子シャフト (鉄)
            gimbalCtx.strokeStyle = "#cbd5e1";
            gimbalCtx.lineWidth = 2.5;
            gimbalCtx.beginPath();
            gimbalCtx.moveTo(pivot.x, pivot.y);
            gimbalCtx.lineTo(weightPos.x, weightPos.y);
            gimbalCtx.stroke();

            // 振り子の重り (球)
            gimbalCtx.fillStyle = "#64748b";
            gimbalCtx.strokeStyle = "#475569";
            gimbalCtx.lineWidth = 2;
            gimbalCtx.beginPath();
            gimbalCtx.arc(weightPos.x, weightPos.y, 8, 0, Math.PI * 2);
            gimbalCtx.fill();
            gimbalCtx.stroke();

            // オレンジの指示指針 (Needle)
            gimbalCtx.strokeStyle = "#f97316"; // ネオンオレンジ
            gimbalCtx.lineWidth = 3;
            gimbalCtx.beginPath();
            gimbalCtx.moveTo(pivot.x, pivot.y);
            gimbalCtx.lineTo(needlePos.x, needlePos.y);
            gimbalCtx.stroke();

            // 指針の先端の赤いドット (文字盤投影イメージ)
            gimbalCtx.fillStyle = "#ef4444";
            gimbalCtx.beginPath();
            gimbalCtx.arc(needlePos.x, needlePos.y, 3.5, 0, Math.PI * 2);
            gimbalCtx.fill();

            // E. 最上部の半透明文字盤 (ガラスドームプレート)
            gimbalCtx.fillStyle = "rgba(59, 130, 246, 0.04)";
            gimbalCtx.strokeStyle = "rgba(59, 130, 246, 0.25)";
            gimbalCtx.lineWidth = 1;
            const glassCircle = [];
            for (let a = 0; angle = (a / 32) * Math.PI * 2, a <= 32; a++) {
                glassCircle.push(project(Math.cos(angle) * 0.8, Math.sin(angle) * 0.8, 0.65));
            }
            gimbalCtx.beginPath();
            glassCircle.forEach((p, idx) => {
                if (idx === 0) gimbalCtx.moveTo(p.x, p.y);
                else gimbalCtx.lineTo(p.x, p.y);
            });
            gimbalCtx.fill();
            gimbalCtx.stroke();
        }

        // ----------------------------------------------------
        // 9. 週刊誌2冊重ねシミュレーター描画
        // ----------------------------------------------------
        function drawBooks() {
            const w = booksCanvas.width = booksCanvas.clientWidth;
            const h = booksCanvas.height = booksCanvas.clientHeight;
            booksCtx.clearRect(0, 0, w, h);

            const groundY = h - 25;
            const cx = w / 2;

            // 地面（車体の床面）
            booksCtx.strokeStyle = "rgba(75, 85, 99, 0.6)";
            booksCtx.lineWidth = 3;
            booksCtx.beginPath();
            booksCtx.moveTo(20, groundY);
            booksCtx.lineTo(w - 20, groundY);
            booksCtx.stroke();

            // 下車（床の模様、センターマーカー）
            booksCtx.strokeStyle = "rgba(220, 38, 38, 0.3)";
            booksCtx.lineWidth = 1.5;
            booksCtx.setLineDash([3, 3]);
            booksCtx.beginPath();
            booksCtx.moveTo(cx, groundY + 15);
            booksCtx.lineTo(cx, groundY - 60);
            booksCtx.stroke();
            booksCtx.setLineDash([]);

            // 週刊誌1 (下巻：ある程度は滑りやすいが車体の摩擦でやや遅れる)
            // 下巻のサイズ
            const bookW = 100;
            const bookH = 20;
            
            // 下巻のGによる僅かな滑り (上巻の半分の力で遅れて動く)
            const lowerOffsetX = state.books.offsetX * 0.35;
            
            // 週刊誌1（下巻：赤）
            const b1X = cx - bookW / 2 + lowerOffsetX;
            const b1Y = groundY - bookH;
            
            booksCtx.fillStyle = "#1e293b";
            booksCtx.strokeStyle = "#475569";
            booksCtx.lineWidth = 2;
            booksCtx.beginPath();
            booksCtx.roundRect(b1X, b1Y, bookW, bookH, 3);
            booksCtx.fill();
            booksCtx.stroke();
            
            // 背表紙・ページ
            booksCtx.fillStyle = "#f8fafc";
            booksCtx.fillRect(b1X + 4, b1Y + 3, bookW - 8, bookH - 6);
            booksCtx.fillStyle = "#b91c1c"; // タイトル風
            booksCtx.font = "bold 9px 'Noto Sans JP'";
            booksCtx.fillText("GT 攻略下巻", b1X + 15, b1Y + 13);

            // 週刊誌2 (上巻：非常にツルッとしている、一番滑る)
            const b2X = cx - bookW / 2 + state.books.offsetX;
            const b2Y = b1Y - bookH;

            // 崩落状態でない場合のみ上巻を描画
            if (!state.books.isFallen) {
                booksCtx.fillStyle = "#0f172a";
                booksCtx.strokeStyle = "#64748b";
                booksCtx.lineWidth = 2;
                booksCtx.beginPath();
                booksCtx.roundRect(b2X, b2Y, bookW, bookH, 3);
                booksCtx.fill();
                booksCtx.stroke();

                // ページとネオンオレンジのカバー
                booksCtx.fillStyle = "#f1f5f9";
                booksCtx.fillRect(b2X + 4, b2Y + 3, bookW - 8, bookH - 6);
                booksCtx.fillStyle = "#f97316";
                booksCtx.font = "bold 9px 'Noto Sans JP'";
                booksCtx.fillText("週刊G-BOWL上", b2X + 15, b2Y + 13);
            } else {
                // 完全に滑り落ちた上巻（床面に横たわる）
                const fallenX = cx - bookW / 2 + (state.books.offsetX > 0 ? 110 : -110);
                const fallenY = groundY - bookH;
                
                booksCtx.save();
                // 若干傾いて落ちている
                booksCtx.translate(fallenX + bookW/2, fallenY + bookH/2);
                booksCtx.rotate(state.books.offsetX > 0 ? 0.08 : -0.08);
                
                booksCtx.fillStyle = "rgba(15, 23, 42, 0.85)";
                booksCtx.strokeStyle = "rgba(100, 116, 139, 0.8)";
                booksCtx.lineWidth = 2;
                booksCtx.beginPath();
                booksCtx.roundRect(-bookW/2, -bookH/2, bookW, bookH, 3);
                booksCtx.fill();
                booksCtx.stroke();
                
                booksCtx.fillStyle = "rgba(241, 245, 249, 0.9)";
                booksCtx.fillRect(-bookW/2 + 4, -bookH/2 + 3, bookW - 8, bookH - 6);
                
                booksCtx.restore();
            }
        }

        // ----------------------------------------------------
        // 10. メイン物理演算エンジン (REAL-TIME ENGINE)
        // ----------------------------------------------------
        let lastTime = performance.now();

        function physicsUpdate(now) {
            let dt = (now - lastTime) / 1000;
            if (dt > 0.1) dt = 0.1; // 極端なラグ防止
            lastTime = now;

            if (state.isRunning) {
                state.currentTime += dt;

                // コースおよび走行スタイルに応じたGデータの取得
                const activeCourse = Courses[state.courseKey];
                const isRace = state.vehicleStyle === "race";
                const gProfile = activeCourse.getG(state.currentTime, isRace);

                // キャリブレーションオフセットの適用
                let targetAx = gProfile.ax;
                let targetAy = gProfile.ay;
                
                if (state.isCalibrated) {
                    targetAx -= state.calibrationOffset.x;
                    targetAy -= state.calibrationOffset.y;
                }

                state.car.ax = targetAx;
                state.car.ay = targetAy;
                state.car.az = gProfile.az;
                state.car.speed = gProfile.speed;
                state.car.sector = gProfile.sector;

                // Gの履歴をボウル描画用に記録 (30点分)
                gHistory.push({ x: targetAx, y: targetAy });
                if (gHistory.length > 50) gHistory.shift();

                // アラート音響処理
                const horizontalG = Math.sqrt(targetAx*targetAx + targetAy*targetAy);
                if (horizontalG > 0.40) {
                    // 超過しきい値
                    if (Math.random() < 0.15) {
                        playBeep(880, 0.08, 0.15); // ピピッと高い警告音
                    }
                } else if (horizontalG > 0.30) {
                    if (Math.random() < 0.05) {
                        playBeep(660, 0.05, 0.08); // 穏やかなアラート
                    }
                }
            } else {
                // 非走行時はGを滑らかに0へ落ち着かせる
                state.car.ax += (0 - state.car.ax) * 0.1;
                state.car.ay += (0 - state.car.ay) * 0.1;
                state.car.az += (1.0 - state.car.az) * 0.1;
                state.car.speed += (0 - state.car.speed) * 0.1;
                state.car.sector = "停止状態";
                
                if (gHistory.length > 0) gfbClearHistory();
            }

            // A. 振り子・ジンバル機構のリアルタイム運動方程式（ニュートン力学オイラー積分）
            updateGimbalPhysics(dt);

            // B. バーチャル「週刊誌」のズレ・崩落物理演算
            updateBooksPhysics(dt);

            // 表示HUDの更新
            updateHUDDisplay();

            // 描画
            drawCourseMap();
            drawGBowl();
            drawGimbal3D();
            drawBooks();

            requestAnimationFrame(physicsUpdate);
        }

        // Gの履歴を徐々に消去する
        function gfbClearHistory() {
            if (Math.random() < 0.2) {
                gHistory.shift();
            }
        }

        // ----------------------------------------------------
        // 11. ジンバルの動的物理シミュレーション (ダンパー3特性対応)
        // ----------------------------------------------------
        function updateGimbalPhysics(dt) {
            // 物理運動パラメータ
            const gravity = 9.81;
            const pendulumLength = 0.2; // 仮想振り子の長さ
            const inertia = 0.05; // 慣性モーメント
            
            // 加速度Gを力(N)に換算。Gフォースによる見かけの力が働く
            // ax, ay の値そのものが慣性力として振り子を逆方向に傾ける
            const forceX = -state.car.ax * gravity; // 前後
            const forceY = state.car.ay * gravity;  // 左右 (座標系の整合：遠心力は外へ)

            // ダンパー性能による減衰項 C の計算
            let c = parseFloat(state.dampingCoeff);
            let dynamicDampingX = 0;
            let dynamicDampingY = 0;

            if (state.dampingType === "liquid") {
                // 1. 液体ダンパー: 速度に完璧に比例する粘性抵抗
                dynamicDampingX = c * state.pendulum.omegaX;
                dynamicDampingY = c * state.pendulum.omegaY;
            } 
            else if (state.dampingType === "magnetic") {
                // 2. 磁気ダンパー: 非常に摩擦がゼロのクリーンな粘性抵抗 (しなやか、やや強めに)
                dynamicDampingX = (c * 1.3) * state.pendulum.omegaX;
                dynamicDampingY = (c * 1.3) * state.pendulum.omegaY;
            } 
            else if (state.dampingType === "friction") {
                // 3. 摩擦ダンパー (Coulomb摩擦 & 静止摩擦ヒステリシス)
                // 速度が極めて遅く、かつかかる力が一定以下なら運動を停止（カクカク動く、0に完全に戻らない）
                const dryFrictionCoeff = 0.5; // 動摩擦力
                const staticFrictionLimit = 0.7; // 静摩擦力

                // 前後軸 (X)
                const totalAppliedTorqueX = forceX * Math.cos(state.pendulum.thetaX) - gravity * Math.sin(state.pendulum.thetaX);
                if (Math.abs(state.pendulum.omegaX) < 0.02 && Math.abs(totalAppliedTorqueX) < staticFrictionLimit) {
                    state.pendulum.omegaX = 0;
                } else {
                    // 動摩擦ブレーキ
                    const frictionDirection = state.pendulum.omegaX > 0 ? 1 : -1;
                    dynamicDampingX = frictionDirection * dryFrictionCoeff + (c * 0.2) * state.pendulum.omegaX;
                }

                // 左右軸 (Y)
                const totalAppliedTorqueY = forceY * Math.cos(state.pendulum.thetaY) - gravity * Math.sin(state.pendulum.thetaY);
                if (Math.abs(state.pendulum.omegaY) < 0.02 && Math.abs(totalAppliedTorqueY) < staticFrictionLimit) {
                    state.pendulum.omegaY = 0;
                } else {
                    const frictionDirection = state.pendulum.omegaY > 0 ? 1 : -1;
                    dynamicDampingY = frictionDirection * dryFrictionCoeff + (c * 0.2) * state.pendulum.omegaY;
                }
            }

            // 運動方程式（角加速度α = トルク/慣性）
            // トルク T = F * L * cos(theta) - m * g * L * sin(theta) - damping
            const torqueX = (forceX * pendulumLength * Math.cos(state.pendulum.thetaX) 
                             - gravity * pendulumLength * Math.sin(state.pendulum.thetaX)) - dynamicDampingX;
            const torqueY = (forceY * pendulumLength * Math.cos(state.pendulum.thetaY) 
                             - gravity * pendulumLength * Math.sin(state.pendulum.thetaY)) - dynamicDampingY;

            const alphaX = torqueX / inertia;
            const alphaY = torqueY / inertia;

            // オイラー法積分
            state.pendulum.omegaX += alphaX * dt;
            state.pendulum.omegaY += alphaY * dt;
            state.pendulum.thetaX += state.pendulum.omegaX * dt;
            state.pendulum.thetaY += state.pendulum.omegaY * dt;

            // 限界角度制限 (ジンバルリングの物理衝突制限 ±45度相当)
            const angleLimit = Math.PI / 4;
            if (state.pendulum.theta/X > angleLimit) { state.pendulum.thetaX = angleLimit; state.pendulum.omegaX = 0; }
            if (state.pendulum.thetaX < -angleLimit) { state.pendulum.thetaX = -angleLimit; state.pendulum.omegaX = 0; }
            if (state.pendulum.thetaY > angleLimit) { state.pendulum.thetaY = angleLimit; state.pendulum.omegaY = 0; }
            if (state.pendulum.thetaY < -angleLimit) { state.pendulum.thetaY = -angleLimit; state.pendulum.omegaY = 0; }
        }

        // ----------------------------------------------------
        // 12. 週刊誌2冊重ねの物理挙動
        // ----------------------------------------------------
        function updateBooksPhysics(dt) {
            if (state.books.isFallen) return;

            // 水平の合成Gの大きさ
            const hG = Math.sqrt(state.car.ax * state.car.ax + state.car.ay * state.car.ay);
            
            // 本の物理モデル：週刊誌間の摩擦係数
            const staticFriction = 0.30;  // 0.30Gまでは滑らない
            const kineticFriction = 0.22; // 滑りだすと一気に動く

            if (hG > staticFriction) {
                // 滑り発生！
                indicatorBookSlip.classList.remove("hidden");
                txtBookStatus.innerText = hG > 0.40 ? "急激な滑り(崩落寸前)" : "滑り出し(0.3G超)";
                txtBookStatus.className = "text-xs text-amber-500 font-bold";

                // 加速度によるスライド速度の計算
                // 滑り方向ベクトル
                const slipAngle = Math.atan2(state.car.ay, -state.car.ax); // Ax, Ayから方向決定
                const forceMag = hG - kineticDamping(hG); // 摩擦を差し引いた有効力
                
                // 本の変位
                state.books.velX += Math.sin(slipAngle) * forceMag * 150 * dt;
                state.books.velY += Math.cos(slipAngle) * forceMag * 150 * dt;
            } else {
                // 静止状態：車体が緩やかに減速・中心に戻る傾向なら、ゆっくり中央に戻る復元力を働かせる（マイルドに積む戻し効果）
                indicatorBookSlip.classList.add("hidden");
                txtBookStatus.innerText = "安定静止 (0.2G以下)";
                txtBookStatus.className = "text-xs text-green-400 font-bold";

                // 本の復元力 (床の滑り止め効果、滑り終えるとゆっくり中心に戻るアライニング特性)
                state.books.velX += (0 - state.books.offsetX) * 2.5 * dt;
                state.books.velY += (0 - state.books.offsetY) * 2.5 * dt;

                // 速度減衰
                state.books.velX *= 0.85;
                state.books.velY *= 0.85;
            }

            // 位置の更新
            stateBooksUpdate();

            // 0.4G超過時の完全落下（崩落）判定
            if (hG > 0.42) {
                const bookSlipDist = Math.sqrt(state.books.offsetX * state.books.offsetX + state.books.offsetY * state.books.offsetY);
                if (bookSlipDist > 55) {
                    state.books.isFallen = true;
                    indicatorBookFall.classList.remove("hidden");
                    playFallSound();
                }
            }
        }

        // 摩擦補正
        function kineticDamping(hG) {
            return 0.20; // 動摩擦係数相当の力
        }

        function stateBooksUpdate() {
            state.books.offsetX += state.books.velX * 0.1;
            state.books.offsetY += state.books.velY * 0.1;

            // 滑り落ちる限界範囲の視覚的制限
            const maxSlide = 140;
            const dist = Math.sqrt(state.books.offsetX * state.books.offsetX + state.books.offsetY * state.books.offsetY);
            if (dist > maxSlide) {
                // 完全に落下状態にする
                state.books.isFallen = true;
                indicatorBookFall.classList.remove("hidden");
                playBookFallSound();
            }

            // HUD表示の更新
            const dispDist = (dist * 0.4).toFixed(1); // 仮想mmに換算
            txtBookSlipDist.innerText = `${dispDist} mm`;
            
            // プログレスバーの更新 (0.4Gライン＝最大許容量の比率)
            const percent = Math.min(100, (dist / 110) * 100);
            barBookSlip.style.width = `${percent}%`;
            if (percent > 80) {
                barBookSlip.className = "bg-red-500 h-full transition-all duration-100";
            } else if (percent > 40) {
                barBookSlip.className = "bg-yellow-500 h-full transition-all duration-100";
            } else {
                barBookSlip.className = "bg-green-500 h-full transition-all duration-100";
            }
        }

        // ----------------------------------------------------
        // 13. HUDデジタル表示更新
        // ----------------------------------------------------
        const txtBookStatus = document.getElementById("book-status");
        const indicatorBookFall = document.getElementById("book-fall-indicator");

        function updateHUDDisplay() {
            hudSpeed.innerText = Math.round(state.car.speed);
            
            const totalG = Math.sqrt(state.car.ax * state.car.ax + state.car.ay * state.car.ay);
            hudTotalG.innerText = totalG.toFixed(2);
            hudZG.innerText = state.car.az.toFixed(2);

            valGx.innerText = `${state.car.ax >= 0 ? "+" : ""}${state.car.ax.toFixed(2)}G`;
            valGy.innerText = `${state.car.ay >= 0 ? "+" : ""}${state.car.ay.toFixed(2)}G`;
            valGz.innerText = `${state.car.az.toFixed(2)}G`;

            // Gの強さに応じてテキストカラーを変更
            if (totalG > 0.4) {
                hudTotalG.className = "text-3xl font-black text-red-500 lcd-font";
            } else if (totalG > 0.2) {
                hudTotalG.className = "text-3xl font-black text-yellow-500 lcd-font";
            } else {
                hudTotalG.className = "text-3xl font-black text-green-400 lcd-font";
            }
        }

        // ----------------------------------------------------
        // 14. 各種コントロール・イベントリスナー設定
        // ----------------------------------------------------
        
        // A. Welcomeモーダルのクリック
        btnStartSimulation.addEventListener("click", () => {
            initAudio();
            modal.style.display = "none";
            // 開始ビープ
            playBeep(440, 0.1, 0.1);
            setTimeout(() => playBeep(880, 0.15, 0.1), 120);
        });

        // B. 自動走行 スタート・ストップ
        btnRun.addEventListener("click", () => {
            initAudio();
            state.isRunning = !state.isRunning;
            
            if (state.isRunning) {
                btnRun.innerHTML = `<i class="fa-solid fa-stop"></i> <span>シミュレーション 停止</span>`;
                btnRun.className = "w-full bg-gray-800 hover:bg-gray-700 text-white font-black py-4 px-6 rounded-xl border border-gray-700 shadow-lg text-lg tracking-widest transition transform active:scale-95 flex items-center justify-center space-x-3 mb-4";
                statusBadge.innerHTML = `<span class="w-2.5 h-2.5 rounded-full bg-red-500"></span> ACTIVE RUNNING`;
                statusBadge.className = "px-3 py-1 rounded-full text-xs font-bold bg-red-500/20 text-red-400 border border-red-500/30 flex items-center gap-1.5 animate-pulse";
                playBeep(523, 0.08, 0.1);
                setTimeout(() => playBeep(659, 0.08, 0.1), 80);
                setTimeout(() => playBeep(784, 0.15, 0.1), 160);
            } else {
                btnRun.innerHTML = `<i class="fa-solid fa-play"></i> <span>自動走行 スタート</span>`;
                btnRun.className = "w-full bg-red-600 hover:bg-red-500 text-white font-black py-4 px-6 rounded-xl border border-red-500 shadow-lg text-lg tracking-widest transition transform active:scale-95 flex items-center justify-center space-x-3 mb-4";
                statusBadge.innerHTML = `<span class="w-2 h-2 rounded-full bg-amber-400"></span> READY`;
                statusBadge.className = "px-3 py-1 rounded-full text-xs font-bold bg-amber-500/20 text-amber-400 border border-amber-500/30 flex items-center gap-1.5 animate-pulse";
                playBeep(784, 0.08, 0.1);
                setTimeout(() => playBeep(523, 0.15, 0.1), 100);
            }
        });

        // C. コース選択
        selectCourse.addEventListener("change", (e) => {
            state.courseKey = e.target.value;
            state.currentTime = 0; // 時間リセット
            gHistory = []; // 履歴リセット
            playBeep(440, 0.1, 0.1);
        });

        // D. 走行スタイル
        styleEco.addEventListener("click", () => {
            state.vehicleStyle = "eco";
            styleEco.className = "py-2.5 px-3 rounded-lg text-xs font-bold border border-emerald-500 bg-emerald-500/10 text-emerald-400 flex flex-col items-center justify-center hover:bg-emerald-500/20 transition duration-150";
            styleRace.className = "py-2.5 px-3 rounded-lg text-xs font-bold border border-gray-700 bg-gray-900 text-gray-400 flex flex-col items-center justify-center hover:bg-gray-800 transition duration-150";
            playBeep(330, 0.1, 0.1);
        });
        styleRace.addEventListener("click", () => {
            state.vehicleStyle = "race";
            styleRace.className = "py-2.5 px-3 rounded-lg text-xs font-bold border border-red-500 bg-red-500/10 text-red-400 flex flex-col items-center justify-center hover:bg-red-500/20 transition duration-150";
            styleEco.className = "py-2.5 px-3 rounded-lg text-xs font-bold border border-gray-700 bg-gray-900 text-gray-400 flex flex-col items-center justify-center hover:bg-gray-800 transition duration-150";
            playBeep(587, 0.1, 0.1);
        });

        // E. ダンパータイプ選択
        const radiosDamping = document.querySelectorAll('input[name="damping-type"]');
        radiosDamping.forEach(radio => {
            radio.addEventListener("change", (e) => {
                state.dampingType = e.target.value;
                updateDampingUI();
                playBeep(440, 0.08, 0.1);
            });
        });

        function updateDampingUI() {
            // 全て非アクティブ化
            document.getElementById("lbl-damping-liquid").className = "cursor-pointer border border-gray-800 bg-gray-900 text-gray-400 p-2 rounded flex flex-col items-center justify-center";
            document.getElementById("lbl-damping-magnetic").className = "cursor-pointer border border-gray-800 bg-gray-900 text-gray-400 p-2 rounded flex flex-col items-center justify-center";
            document.getElementById("lbl-damping-friction").className = "cursor-pointer border border-gray-800 bg-gray-900 text-gray-400 p-2 rounded flex flex-col items-center justify-center";

            if (state.dampingType === "liquid") {
                document.getElementById("lbl-damping-liquid").className = "cursor-pointer border border-blue-500 bg-blue-500/10 text-blue-400 p-2 rounded flex flex-col items-center justify-center";
                dampingExplainBox.innerHTML = `
                    <span class="font-bold text-blue-400 block mb-1">💧 液体ダンパー (Liquid Damper)</span>
                    液体の粘り気を利用した標準的な減衰。滑らかに計器が落ち着きますが、温度変化や液漏れの欠点があります。
                `;
            } else if (state.dampingType === "magnetic") {
                document.getElementById("lbl-damping-magnetic").className = "cursor-pointer border border-amber-500 bg-amber-500/10 text-amber-400 p-2 rounded flex flex-col items-center justify-center";
                dampingExplainBox.innerHTML = `
                    <span class="font-bold text-amber-400 block mb-1">🧲 磁気ダンパー (Magnetic Damper)</span>
                    電磁誘導による渦電流ブレーキを利用。非接触のため磨耗がなく極めて高精度で滑らか、精密天秤などに使われます。
                `;
            } else if (state.dampingType === "friction") {
                document.getElementById("lbl-damping-friction").className = "cursor-pointer border border-red-500 bg-red-500/10 text-red-400 p-2 rounded flex flex-col items-center justify-center";
                dampingExplainBox.innerHTML = `
                    <span class="font-bold text-red-400 block mb-1">⚙️ 摩擦ダンパー (Friction Damper)</span>
                    ブレーキパッドを物理接触させ摩擦力で制振。静摩擦（ひっかかり）があるため微細なGでカクついたり、元の位置に完全に戻らない「ヒステリシス誤差」を物理再現します。
                `;
            }
        }

        // F. ダンパー係数
        sliderDamping.addEventListener("input", (e) => {
            state.dampingCoeff = e.target.value;
            valDamping.innerText = parseFloat(state.dampingCoeff).toFixed(1);
        });

        // G. キャリブレーション (ゼロ点補正)
        btnCalibrate.addEventListener("click", () => {
            initAudio();
            // 現在のGをオフセットにする
            if (state.isRunning) {
                // デモ走行中のゼロ点調整
                state.calibrationOffset.x = state.car.ax;
                state.calibrationOffset.y = state.car.ay;
                state.isCalibrated = true;
            } else {
                // 停止状態ならリセット
                state.calibrationOffset = { x: 0, y: 0 };
                state.isCalibrated = false;
            }
            playBeep(880, 0.1, 0.15);
            
            // 一時的にステータスバッジに「CALIBRATION DONE」と表示
            const originalBadge = statusBadge.innerHTML;
            const originalClass = statusBadge.className;
            statusBadge.innerHTML = `<i class="fa-solid fa-check"></i> CALIBRATED`;
            statusBadge.className = "px-3 py-1 rounded-full text-xs font-bold bg-green-500/20 text-green-400 border border-green-500/30 flex items-center gap-1.5";
            setTimeout(() => {
                statusBadge.innerHTML = originalBadge;
                statusBadge.className = originalClass;
            }, 1500);
        });

        // H. サウンドON/OFFトグル
        btnToggleSound.addEventListener("click", () => {
            state.soundEnabled = !state.soundEnabled;
            if (state.soundEnabled) {
                btnToggleSound.innerHTML = `<i class="fa-solid fa-volume-high"></i>`;
                btnToggleSound.className = "text-xl text-green-400 p-2 rounded hover:bg-gray-800 transition";
                initAudio();
                playBeep(880, 0.1, 0.1);
            } else {
                btnToggleSound.innerHTML = `<i class="fa-solid fa-volume-xmark"></i>`;
                btnToggleSound.className = "text-xl text-gray-500 p-2 rounded hover:bg-gray-800 transition";
            }
        });

        // I. 本を積み直す
        btnStackBooks.addEventListener("click", () => {
            initAudio();
            state.books.offsetX = 0;
            state.books.offsetY = 0;
            state.books.velX = 0;
            state.books.velY = 0;
            state.books.isFallen = false;
            indicatorBookFall.classList.add("hidden");
            txtBookStatus.innerText = "安定静止 (0.2G以下)";
            txtBookStatus.className = "text-xs text-green-400 font-bold";
            barBookSlip.style.width = "0%";
            playBeep(523, 0.1, 0.15);
            setTimeout(() => playBeep(659, 0.1, 0.1), 100);
        });

        // ----------------------------------------------------
        // 15. 初期化と起動
        // ----------------------------------------------------
        window.onload = function() {
            // 描画ループ起動
            requestAnimationFrame(physicsUpdate);
        };
    </script>
</body>
